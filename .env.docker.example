# ──────────────────────────────────────────────────────────────
# GC Communication — admin panel (Docker / production)
#
# On your server:
#   cp .env.docker.example .env
#   make setup      # fills APP_KEY for you
#   # edit the DB_* passwords below, then:
#   make up
# ──────────────────────────────────────────────────────────────

APP_NAME="GC Communication"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://admin.gc-communication.in

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Port published on the host (http://your-server:8080 by default)
APP_PORT=8080

# Create the initial admin user on first boot, then set back to false.
APP_SEED=true

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Database — these values are shared between the app and the MySQL container.
# DB_HOST is forced to the "db" service by docker-compose; no need to change it.
DB_CONNECTION=mysql
DB_DATABASE=gc_communication
DB_USERNAME=gc_user
DB_PASSWORD=change-me-strong-password
DB_ROOT_PASSWORD=change-me-strong-root-password

# DB-backed sessions/cache/queue — no extra services required.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@gc-communication.in"
MAIL_FROM_NAME="${APP_NAME}"

# Admin panel branding (see config/admin.php)
ADMIN_NAME="GC Communication"
ADMIN_LOGO="/images/gc-logo.svg"
ADMIN_TIMEZONE="Asia/Kolkata"

VITE_APP_NAME="${APP_NAME}"
